DEEPSEEK_API_KEY=your_deepseek_api_key
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Renderer (auth/friends). Must be set before "npm run build" for Friends to work in production.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional — path to a mascot PNG overlaid on the release card. Leave unset to hide.
# Example: GRINDLY_MASCOT=C:/Users/you/mascot.png
GRINDLY_MASCOT=
